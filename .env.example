# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://statedge:statedge@localhost:5432/statedge
DATABASE_URL_SYNC=postgresql://statedge:statedge@localhost:5432/statedge

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:5173","http://localhost:4173"]

# ── External data (optional — live scores disabled without these) ──────────────
# football-data.org free tier: https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# CollegeFootballData free API key: https://collegefootballdata.com/key
CFBD_API_KEY=

# SportRadar (paid): https://developer.sportradar.com
SPORTRADAR_API_KEY=

# ── Environment ───────────────────────────────────────────────────────────────
ENV=development
LOG_LEVEL=INFO

# ── Model (defaults are pre-calibrated — only change if retraining) ───────────
ELO_MU=1.06
ELO_Q=1540
ELO_HOST_EDGE=150
SR_BLEND_WEIGHT=0.60
MONTE_CARLO_SIMS=50000
