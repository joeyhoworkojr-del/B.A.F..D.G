# ==========================================================================
# Elysium Bio Labs — environment variables
# Copy this file to .env.local and fill in real values.
# ==========================================================================

# Public site URL (used for canonical URLs, sitemap, and Open Graph metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --------------------------------------------------------------------------
# Email provider (optional — not required for local development).
# In development, contact submissions are logged to ./.logs/inquiries.log.
# To send real email, connect a provider in app/api/contact/route.ts
# (Resend and SendGrid examples are included there) and set the keys below.
# --------------------------------------------------------------------------
# RESEND_API_KEY=
# SENDGRID_API_KEY=
# CONTACT_NOTIFICATION_EMAIL=inquiries@example.com
